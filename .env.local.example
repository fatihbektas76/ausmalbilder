# Ausmalbilder Gratis — Environment Variables
# Kopiere diese Datei nach .env.local und trage die echten Werte ein.

# Site
NEXT_PUBLIC_SITE_URL=https://ausmalbilder-gratis.com
NEXT_PUBLIC_ASSETS_URL=https://assets.ausmalbilder-gratis.com

# Cloudflare R2 (S3-kompatibel)
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=ausmalbilder-gratis-assets

# Google AdSense (optional, nach Freischaltung)
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxx

# Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-xxxxxxxxxx
